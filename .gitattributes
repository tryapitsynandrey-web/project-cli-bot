# Normalize line endings for all text files
* text=auto

# Python / source code
*.py  text eol=lf

# Documentation
*.md  text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Configuration / metadata
*.toml text eol=lf
*.ini  text eol=lf
*.cfg  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.lock text eol=lf

# Shell / environment scripts
*.sh  text eol=lf
*.env text eol=lf

# Git / repo files
.gitignore     text eol=lf
.gitattributes text eol=lf

# Optional dev / CI files
*.patch text eol=lf
*.diff  text eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary

# Local databases / runtime data
*.sqlite3         binary
*.sqlite3-journal binary